# =============================================================================
# JKST Master AI — Environment Configuration
# GX10 Performance-Tuned Defaults
# =============================================================================

# ---------- Google Cloud Configuration ----------
GCP_PROJECT_ID=
GCP_RAG_LOCATION=
GCP_GEMINI_LOCATION=
GCP_RAG_CORPUS_ID=
GCP_GEMINI_MODEL=gemini-2.0-flash-001

# GCS Bucket for document storage and downloads
GCS_BUCKET_NAME=

# ---------- RAG Mode ----------
# google = Cloud (Vertex AI + Gemini + Cohere)
# local  = On-premise (ChromaDB + Sentence-Transformers + Gemini LLM)
# ultra  = Maximum (Hybrid Search + Query Expansion + Cross-Encoder + Self-Eval)
# Recommended for GX10: ultra (GPU handles the extra compute)
RAG_MODE=ultra

# ---------- LLM Provider (YTL Ilmu — free Malaysian AI) ----------
# When LOCAL_LLM_API_KEY is set, local/ultra modes use YTL instead of Gemini
# This means NO Google Cloud credentials needed for local/ultra modes!
LOCAL_LLM_BASE_URL=https://api.ytlailabs.tech/v1
LOCAL_LLM_API_KEY=
LOCAL_LLM_MODEL=ilmu-text-free-v2
LOCAL_LLM_TOOL_WORKAROUND=true

# ---------- API Keys ----------
# Tavily API for real-time web search (optional)
TAVILY_API_KEY=

# Cohere API for reranking (optional — ultra mode uses cross-encoder instead)
COHERE_API_KEY=

# Reranker type: 'gemini' or 'cohere' (only used in google mode)
RERANKER_TYPE=gemini

# Base URL for download links (used in AI responses)
BASE_URL=

# ---------- Telegram Bot ----------
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=

# ---------- Voice Features (STT + TTS) ----------
# OpenAI API key for Whisper STT
OPENAI_API_KEY=

# Google Cloud TTS Configuration
TTS_LANGUAGE_CODE=ms-MY
TTS_VOICE_NAME=ms-MY-Wavenet-A

# =============================================================================
# GX10 PERFORMANCE TUNING
# =============================================================================

# --- GPU Acceleration ---
# Device for embedding model (cuda/cpu). GX10 GB10 GPU = use cuda.
EMBEDDING_DEVICE=cuda
# Device for cross-encoder reranker (cuda/cpu)
CROSS_ENCODER_DEVICE=cuda

# --- HuggingFace Model Cache ---
# Store on NVMe for fast model loading
HF_HOME=/opt/jkst-master-ai/.hf_cache

# --- Retrieval Tuning ---
# How many docs to retrieve initially (more = better recall, GPU handles it)
LOCAL_RETRIEVAL_TOP_K=15
ULTRA_RETRIEVAL_TOP_K=20
RAG_INITIAL_RESULTS=20
# How many docs after reranking (quality over quantity)
RAG_FINAL_RESULTS=7
# Enable reranking
ENABLE_RERANKING=true

# --- Embedding Tuning ---
# Batch size for GPU embedding (GX10 unified memory handles large batches)
EMBEDDING_BATCH_SIZE=256
# Batch size for ChromaDB ingestion
INGEST_BATCH_SIZE=500

# --- Cache Tuning ---
# Response cache TTL (seconds). 10 min = good for demos
CACHE_TTL_SECONDS=600

# =============================================================================
# ULTRA MODE — 100% LOCAL CONFIG
# =============================================================================
# Ollama LLM (runs locally on GPU, no cloud)
ULTRA_LLM_BASE_URL=http://localhost:11434/v1
ULTRA_LLM_MODEL=gemma4

# Local Whisper STT (GPU-accelerated)
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda

# Local TTS (Facebook MMS-TTS Malay)
TTS_LOCAL_MODEL=facebook/mms-tts-zlm
TTS_LOCAL_DEVICE=cuda

# --- Paths ---
CHROMA_PERSIST_DIR=/opt/jkst-master-ai/chroma_db
LOCAL_KNOWLEDGE_PATH=/opt/jkst-master-ai/knowledge
LOCAL_DOCUMENTS_PATH=/opt/jkst-master-ai/documents
CSV_LOG_PATH=/opt/jkst-master-ai/logs/conversations.csv
FEEDBACK_CSV_PATH=/opt/jkst-master-ai/logs/feedback.csv
